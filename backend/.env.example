# Puerto (Railway inyecta PORT automáticamente)
PORT=3000

# MySQL — en Railway, referencia las variables del servicio MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=educationalcontrol

# JWT (obligatorio en producción)
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# Carpeta de archivos subidos (Volume Railway: montar en /app/uploads)
UPLOADS_DIR=./uploads

# APK público (opcional): nombre del archivo en backend/releases/
APK_FILENAME=app.apk

# Email — recuperación de contraseña (opcional)
# En Railway, si Gmail falla por red: añade también NODE_OPTIONS=--dns-result-order=ipv4first
APP_NAME=EducationalControl
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
# RESEND_API_KEY=
# EMAIL_FROM=
